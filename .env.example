# ============================
# 9Router Configuration
# ============================
# URL of your 9Router instance
NINEROUTER_URL=http://localhost:20128

# 9Router login password
NINEROUTER_PASSWORD=your_password_here

# Custom path to 9Router SQLite database (optional, auto-detected if empty)
# Linux/macOS: ~/.9router/db/data.sqlite
# Windows: %APPDATA%/9router/db/data.sqlite
NINEROUTER_DB=

# ============================
# Browser Automation
# ============================
# Set to "false" to show browser window (useful for debugging)
HEADLESS=true

# ============================
# Proxy (Optional)
# ============================
# Format: http://u...t
BATCHER_PROXY_URL=
